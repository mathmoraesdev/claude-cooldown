# Copie este arquivo para ".env" (uso local) OU cole essas variáveis
# nas "Environment Variables" do seu serviço no Render/Railway/etc.

# Gere seu próprio par de chaves com:
#   cd server && npx web-push generate-vapid-keys
# e cole os valores gerados aqui embaixo (ou direto nas env vars do Render).
VAPID_PUBLIC_KEY=cole_sua_chave_publica_aqui
VAPID_PRIVATE_KEY=cole_sua_chave_privada_aqui
VAPID_SUBJECT=mailto:seuemail@example.com

# Porta (o Render/Railway define isso automaticamente, pode ignorar)
PORT=3001
